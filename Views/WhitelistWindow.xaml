<Window x:Class="CassieWordCheck.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CassieWordCheck.Views"
        xmlns:models="clr-namespace:CassieWordCheck.Models"
        mc:Ignorable="d"
        Title="CASSIE CWC Tool"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">
    <!-- 主窗口：CASSIE CWC Tool 的主界面，包含输入框、结果卡和工具栏 -->
<Window x:Class="CassieWordCheck.Views.WhitelistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="白名单管理"
        Width="460" Height="520"
        MinWidth="360" MinHeight="380"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">

    <Border Margin="1" CornerRadius="8" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid Margin="20,16,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="白名单管理"
                       Style="{StaticResource SectionLabel}"
                       FontSize="13"
                       Margin="0,0,0,12" />

            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="NewWordBox"
                         Grid.Column="0"
                         Style="{StaticResource ModernTextBox}"
                         FontSize="13"
                         KeyDown="OnNewWordKeyDown" />
                <Button Grid.Column="1"
                        Style="{StaticResource AccentButton}"
                        Content="+ 添加"
                        Margin="8,0,0,0"
                        Padding="16,8"
                        Click="OnAddWord" />
            </Grid>

            <Border Grid.Row="2"
                    CornerRadius="8"
                    Background="{StaticResource BgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <ItemsControl x:Name="WhitelistItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2,2"
                                        CornerRadius="6"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        Padding="8,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Text}"
                                                   FontSize="13"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Style="{StaticResource DangerButton}"
                                                Content="✕"
                                                Padding="8,2"
                                                FontSize="11"
                                                Click="OnRemoveWord"
                                                Tag="{Binding Text}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <TextBlock x:Name="EmptyLabel"
                       Grid.Row="2"
                       Text="暂无白名单单词，在上方输入添加。"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />

            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource ModernButton}"
                        Content="📥 导入"
                        Padding="14,6"
                        FontSize="12"
                        Click="OnImport" />

                <Button Grid.Column="1"
                        Style="{StaticResource ModernButton}"
                        Content="📤 导出"
                        Padding="14,6"
                        FontSize="12"
                        Margin="8,0,0,0"
                        Click="OnExport" />

                <Button Grid.Column="3"
                        Style="{StaticResource DangerButton}"
                        Content="🗑 清空全部"
                        Padding="14,6"
                        FontSize="12"
                        Click="OnClearAll" />
            </Grid>
        </Grid>
    </Border>
</Window>
