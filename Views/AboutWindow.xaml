<Window x:Class="CassieWordCheck.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于 CASSIE CWC Tool"
        Width="540" Height="620"
        MinWidth="440" MinHeight="520"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        AllowsTransparency="False"
        Loaded="OnLoaded">

    <Window.Resources>
        <Storyboard x:Key="ContentFadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="12" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="ContentFadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-8" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <!-- 主容器：外层带氛围光晕 -->
    <Grid>
        <!-- 氛围光晕装饰 -->
        <Ellipse Width="280" Height="280"
                 Fill="{StaticResource AccentGradientBrush}"
                 Opacity="0.08"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-60,-60,0" />

        <Border Margin="1" CornerRadius="14"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.35"
                                  ShadowDepth="6" Direction="270" Color="#000000" />
            </Border.Effect>
            <Grid Margin="28,28,28,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ═══ 头部：图标 + 标题 + 版本 ═══ -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 应用图标：渐变 + 发光 -->
                    <Border Grid.Column="0"
                            Width="52" Height="52"
                            CornerRadius="14"
                            Background="{StaticResource AccentGradientBrush}"
                            VerticalAlignment="Center"
                            x:Name="AppIconBorder">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" Opacity="0.4"
                                              ShadowDepth="2" Direction="270"
                                              Color="#6C5CE7" />
                        </Border.Effect>
                        <TextBlock Text="C" FontWeight="Bold" FontSize="30"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="CASSIE CWC Tool"
                                   FontSize="20" FontWeight="SemiBold" />
                        <TextBlock x:Name="VersionLabel" Text="版本 2.0.0"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>

                <!-- ═══ 装饰分割线 ═══ -->
                <Rectangle Grid.Row="1" Height="1" Margin="0,0,0,16"
                           Fill="{StaticResource BorderBrush}" Opacity="0.5" />

                <!-- ═══ 标签页 ═══ -->
                <Grid Grid.Row="2" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 功能标签 -->
                    <Border Grid.Column="0" Padding="0,0,0,8">
                        <TextBlock x:Name="FeaturesTab"
                                   Text="项目功能"
                                   FontSize="13" FontWeight="SemiBold"
                                   Cursor="Hand"
                                   MouseDown="OnShowFeatures">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                    <Style.Triggers>
                                        <Trigger Property="Tag" Value="Active">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- 更新日志标签 -->
                    <Border Grid.Column="1" Margin="28,0,0,0" Padding="0,0,0,8">
                        <TextBlock x:Name="ChangelogTab"
                                   Text="更新日志"
                                   FontSize="13" FontWeight="SemiBold"
                                   Cursor="Hand"
                                   MouseDown="OnShowChangelog">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                    <Style.Triggers>
                                        <Trigger Property="Tag" Value="Active">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- 底部指示条 -->
                    <Border Grid.Column="0" Grid.ColumnSpan="2"
                            Width="36" Height="2.5"
                            CornerRadius="2"
                            Background="{StaticResource AccentGradientBrush}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,0">
                        <Border.Resources>
                            <Storyboard x:Key="IndicatorMoveToChangelog">
                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                    To="114,0,0,0" Duration="0:0:0.3">
                                    <ThicknessAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                            <Storyboard x:Key="IndicatorMoveToFeatures">
                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                    To="0,0,0,0" Duration="0:0:0.3">
                                    <ThicknessAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </Border.Resources>
                    </Border>
                </Grid>

                <!-- ═══ 内容区域 ═══ -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                              Padding="0,0,6,0" Margin="0,0,0,0">
                    <TextBlock x:Name="ContentArea"
                               TextWrapping="Wrap"
                               FontSize="12.5"
                               LineHeight="20"
                               Opacity="0"
                               Foreground="{StaticResource TextPrimaryBrush}">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="12" />
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </ScrollViewer>

                <!-- ═══ 底部：制作者信息 ═══ -->
                <Border Grid.Row="4" Margin="0,16,0,0"
                        x:Name="CreditsBorder"
                        Background="{StaticResource BgBrush}"
                        CornerRadius="10"
                        Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 头像 -->
                        <Border Grid.Column="0"
                                Width="40" Height="40"
                                CornerRadius="8"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                VerticalAlignment="Center">
                            <Border.RenderTransform>
                                <RotateTransform x:Name="AvatarRotate" Angle="0" />
                            </Border.RenderTransform>
                            <Image x:Name="AvatarImage" Width="38" Height="38"
                                   Stretch="UniformToFill" />
                        </Border>

                        <!-- 文字 -->
                        <StackPanel Grid.Column="1" Margin="14,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="10.5" LineHeight="15"
                                       Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="清然 (2816401189)" FontWeight="SemiBold" />
                                <Run Text="· 紧急事件制作组" />
                            </TextBlock>
                            <TextBlock FontSize="10" LineHeight="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Opacity="0.6">
                                鸣谢：Awni、虚无 · 本项目由 AI 辅助制作
                            </TextBlock>
                        </StackPanel>

                        <!-- 关闭按钮 -->
                        <Border Grid.Column="2"
                                Width="32" Height="32"
                                CornerRadius="8"
                                Background="Transparent"
                                VerticalAlignment="Center"
                                Cursor="Hand"
                                MouseDown="OnClose">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BorderBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="✕" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
