<Window x:Class="CassieWordCheck.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="500" Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">

    <Border Margin="1" CornerRadius="8" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid Margin="20,16,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="设 置"
                       Style="{StaticResource SectionLabel}"
                       FontSize="13"
                       Margin="0,0,0,12" />

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                <StackPanel>

                    <CheckBox x:Name="IgnoreChineseCheck"
                              Style="{StaticResource ModernCheckBox}"
                              Content="忽略中文字符"
                              Margin="0,0,0,12" />
                    <TextBlock Text="CASSIE 无法读出中文。开启后将跳过中文字符。"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               Margin="28,-8,0,16" />

                    <CheckBox x:Name="IgnoreAngleCheck"
                              Style="{StaticResource ModernCheckBox}"
                              Content="忽略 &lt;&gt; 内容"
                              Margin="0,0,0,12" />
                    <TextBlock Text="部分插件使用 &lt;color=#fff&gt; 标签。开启后将忽略尖括号内的内容。"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               Margin="28,-8,0,16" />

                    <Separator BorderBrush="{StaticResource BorderBrush}" Margin="0,4,0,16" />

                    <TextBlock Text="词库文件路径"
                               Style="{StaticResource SectionLabel}" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="WordlistPathBox"
                                 Grid.Column="0"
                                 Style="{StaticResource ModernTextBox}"
                                 IsReadOnly="True"
                                 Foreground="{StaticResource TextSecondaryBrush}"
                                 FontSize="12" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ModernButton}"
                                Content="浏览..."
                                Margin="8,0,0,0"
                                Padding="16,8"
                                Click="OnBrowseWordlist" />
                    </Grid>

                    <TextBlock Text="主题"
                               Style="{StaticResource SectionLabel}" />
                    <ComboBox x:Name="ThemeSelector"
                              Style="{StaticResource ModernComboBox}"
                              Margin="0,0,0,16"
                              SelectionChanged="OnThemeChanged">
                        <ComboBoxItem Content="深色" />
                        <ComboBoxItem Content="浅色" />
                        <ComboBoxItem Content="系统" />
                    </ComboBox>

                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource ModernButton}"
                        Content="恢复默认"
                        Foreground="{StaticResource TextMutedBrush}"
                        Click="OnResetDefaults" />

                <Button Grid.Column="2"
                        Style="{StaticResource AccentButton}"
                        Content="保存并关闭"
                        Padding="24,8"
                        Click="OnSave" />
            </Grid>
        </Grid>
    </Border>
</Window>
