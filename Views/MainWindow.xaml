<Window x:Class="CassieWordCheck.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CASSIE 单词检查器"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        TextOptions.TextFormattingMode="Display">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             Toolbar
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- App icon / brand -->
                <Border Grid.Column="0"
                        Width="28" Height="28"
                        CornerRadius="8"
                        Background="{StaticResource AccentGradientBrush}"
                        VerticalAlignment="Center">
                    <TextBlock Text="C" FontWeight="Bold" FontSize="16"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <TextBlock Grid.Column="1"
                           Text="CASSIE Word Checker"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />

                <!-- Language selector -->
                <ComboBox x:Name="LanguageSelector"
                          Grid.Column="2"
                          Style="{StaticResource ModernComboBox}"
                          Width="130"
                          Margin="0,0,8,0"
                          SelectionChanged="OnLanguageChanged" />

                <!-- Whitelist button -->
                <Button Grid.Column="3"
                        x:Name="WhitelistButton"
                        Style="{StaticResource ModernButton}"
                        Content="⊞ 白名单"
                        Margin="0,0,8,0"
                        Padding="14,6"
                        Click="OnOpenWhitelist" />

                <!-- Settings button -->
                <Button Grid.Column="4"
                        x:Name="SettingsButton"
                        Style="{StaticResource ModernButton}"
                        Content="⚙ 设置"
                        Padding="14,6"
                        Click="OnOpenSettings" />

                <!-- Reload button -->
                <Button Grid.Column="5"
                        x:Name="ReloadButton"
                        Style="{StaticResource ModernButton}"
                        Content="⟳"
                        Padding="10,6"
                        Margin="0,0,0,0"
                        FontSize="16"
                        ToolTip="重新加载词库"
                        Click="OnReloadWordlist" />
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Word List Status Bar
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" Padding="16,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="#1A1A2E"
                        CornerRadius="4"
                        Padding="8,3">
                    <TextBlock x:Name="WordListInfo"
                               Text="词库：—"
                               Foreground="{StaticResource AccentLightBrush}"
                               FontSize="11"
                               FontFamily="{StaticResource MonoFont}" />
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Main Content - Input & Result Cards
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="16,12,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT: Input Card ───────────────────────────────── -->
            <Border Grid.Column="0"
                    Style="{StaticResource CardStyle}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="广播文本"
                                       Style="{StaticResource SectionLabel}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="CharCountLabel" Grid.Column="2"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11" FontFamily="{StaticResource MonoFont}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Input text area -->
                    <TextBox x:Name="InputBox"
                             Grid.Row="1"
                             Style="{StaticResource ModernTextBox}"
                             BorderThickness="0"
                             Background="Transparent"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="16,12"
                             FontSize="14"
                             TextChanged="OnInputTextChanged" />
                </Grid>
            </Border>

            <!-- ─── RIGHT: Result Card ──────────────────────────────── -->
            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{StaticResource AccentGradientBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="检查结果"
                                       Style="{StaticResource SectionLabel}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="2"
                                    x:Name="CopyButton"
                                    Style="{StaticResource ModernButton}"
                                    Content="📋 复制"
                                    Padding="10,3"
                                    FontSize="11"
                                    Click="OnCopyResult" />
                        </Grid>
                    </Border>

                    <!-- Result display -->
                    <RichTextBox x:Name="ResultBox"
                                 Grid.Row="1"
                                 Style="{StaticResource ModernRichTextBox}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="16,12"
                                 FontSize="14"
                                 IsReadOnly="True" />
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             Suggestions Panel
             ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="SuggestionsPanel"
                Grid.Row="3"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="💡 建议"
                           Style="{StaticResource SectionLabel}"
                           VerticalAlignment="Top"
                           Margin="0,2,16,0" />
                <ItemsControl x:Name="SuggestionsList"
                              Grid.Column="1">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1A2E"
                                    CornerRadius="6"
                                    Padding="10,6"
                                    Margin="0,0,8,6"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{StaticResource ErrorBrush}"
                                               FontSize="12"
                                               Text="{Binding Original}" />
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"
                                               FontFamily="{StaticResource MonoFont}"
                                               Text="{Binding SuggestionText}"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Stats Bar
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>

                <!-- Available -->
                <Border Grid.Column="0" CornerRadius="4" Background="#0A2E1A" Padding="10,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="AvailableLabel"
                                   Text="可用：0"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontSize="11" FontFamily="{StaticResource MonoFont}"
                                   Margin="6,0,0,0" />
                    </Grid>
                </Border>

                <!-- Unavailable -->
                <Border Grid.Column="1" CornerRadius="4" Background="#2D1B1B" Padding="10,6" Margin="8,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="6" Height="6" Fill="{StaticResource ErrorBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="UnavailableLabel"
                                   Text="不可用：0"
                                   Foreground="{StaticResource ErrorBrush}"
                                   FontSize="11" FontFamily="{StaticResource MonoFont}"
                                   Margin="6,0,0,0" />
                    </Grid>
                </Border>

                <!-- Ignored -->
                <Border Grid.Column="2" CornerRadius="4" Background="#1A1A24" Padding="10,6" Margin="8,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="6" Height="6" Fill="{StaticResource IgnoredBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="IgnoredLabel"
                                   Text="已忽略：0"
                                   Foreground="{StaticResource IgnoredBrush}"
                                   FontSize="11" FontFamily="{StaticResource MonoFont}"
                                   Margin="6,0,0,0" />
                    </Grid>
                </Border>

                <!-- Coverage progress bar -->
                <Grid Grid.Column="4" VerticalAlignment="Center">
                    <Border CornerRadius="4" Background="#1A1A24" Width="120" Height="6">
                        <Border x:Name="CoverageBar"
                                CornerRadius="4"
                                Background="{StaticResource AccentGradientBrush}"
                                HorizontalAlignment="Left"
                                Width="0" />
                    </Border>
                </Grid>

                <!-- Coverage text -->
                <TextBlock Grid.Column="6" x:Name="CoverageLabel"
                           Text="0%"
                           Foreground="{StaticResource AccentLightBrush}"
                           FontSize="13" FontWeight="SemiBold"
                           FontFamily="{StaticResource MonoFont}"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />
            </Grid>
        </Border>
    </Grid>
</Window>
