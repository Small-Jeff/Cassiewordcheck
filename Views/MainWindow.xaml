<Window x:Class="CassieWordCheck.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CASSIE CWC Tool"
        Width="880" Height="600"
        MinWidth="680" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        TextOptions.TextFormattingMode="Display"
        Loaded="OnMainWindowLoaded">

    <Grid Margin="24,16,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Toolbar Card (joined with status info) ──────────────── -->
        <Border x:Name="ToolbarCard" Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,0,0,6"
                Padding="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" Opacity="0.3" ShadowDepth="4" Direction="270" Color="#000000" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Top row: toolbar buttons -->
                <Grid Grid.Row="0" Margin="20,0,20,0" Height="48">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="28" Height="28"
                            CornerRadius="8"
                            Background="Transparent"
                            VerticalAlignment="Center">
                        <Image x:Name="ToolbarIcon" Width="28" Height="28"
                               Stretch="UniformToFill" />
                    </Border>

                    <TextBlock Grid.Column="1"
                               Text="CASSIE Word Checker"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0" />

                    <ComboBox x:Name="LanguageSelector"
                              Grid.Column="2"
                              Style="{StaticResource ModernComboBox}"
                              Width="120"
                              Margin="0,0,10,0"
                              VerticalAlignment="Center"
                              SelectionChanged="OnLanguageChanged" />

                    <Button Grid.Column="3"
                            x:Name="WhitelistButton"
                            Style="{StaticResource ModernButton}"
                            Content="⊞ 白名单"
                            Margin="0,0,10,0"
                            Padding="14,6"
                            VerticalAlignment="Center"
                            Click="OnOpenWhitelist" />

                    <Button Grid.Column="4"
                            x:Name="SettingsButton"
                            Style="{StaticResource ModernButton}"
                            Content="⚙ 设置"
                            Padding="14,6"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            Click="OnOpenSettings" />

                    <Button Grid.Column="5"
                            x:Name="ReloadButton"
                            Style="{StaticResource ModernButton}"
                            Content="⟳"
                            Padding="10,6"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="16"
                            ToolTip="重新加载词库"
                            Click="OnReloadWordlist" />

                    <Button Grid.Column="6"
                            x:Name="AboutButton"
                            Style="{StaticResource ModernButton}"
                            Content="ⓘ"
                            Padding="8,6"
                            Width="32"
                            FontSize="15"
                            VerticalAlignment="Center"
                            ToolTip="关于"
                            Click="OnOpenAbout" />

                    <Button Grid.Column="7"
                            x:Name="OpenFileButton"
                            Style="{StaticResource ModernButton}"
                            Content="📂"
                            Padding="8,6"
                            Width="32"
                            FontSize="15"
                            Margin="4,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="打开文本文件"
                            Click="OnOpenFile" />

                    <Button Grid.Column="8"
                            x:Name="HistoryButton"
                            Style="{StaticResource ModernButton}"
                            Content="🕐"
                            Padding="8,6"
                            Width="32"
                            FontSize="15"
                            Margin="4,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="检查历史"
                            Click="OnToggleHistory" />
                </Grid>

                <!-- Separator + status line -->
                <Grid Grid.Row="1" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#1A1A2E"
                            CornerRadius="6"
                            Padding="8,4"
                            Margin="20,8">
                        <TextBlock x:Name="WordListInfo"
                                   Text="词库：—"
                                   Foreground="{StaticResource AccentLightBrush}"
                                   FontSize="11"
                                   FontFamily="{StaticResource MonoFont}" />
                    </Border>

                    <TextBlock Grid.Column="2"
                               Margin="0,0,20,0"
                               VerticalAlignment="Center">
                        <Hyperlink x:Name="WordlistPathLink"
                                   Foreground="{StaticResource AccentLightBrush}"
                                   FontSize="11"
                                   FontFamily="{StaticResource MonoFont}"
                                   TextDecorations="Underline"
                                   NavigateUri="javascript:void(0)"
                                   RequestNavigate="OnOpenWordlistLocation">
                            <Run Text="..." />
                        </Hyperlink>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Main Content - Input & Result Cards
             ═══════════════════════════════════════════════════════════════ -->
        <Grid x:Name="MainContentGrid" Grid.Row="1" Margin="0,0,0,6"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TranslateTransform Y="0" />
            </Grid.RenderTransform>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT: Input Card ───────────────────────────────── -->
            <Border x:Name="InputCard"
                    Grid.Column="0"
                    Style="{StaticResource CardStyle}"
                    Padding="0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" x:Name="InputLabel" Text="广播文本"
                                       Style="{StaticResource SectionLabel}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="CharCountLabel" Grid.Column="2"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11" FontFamily="{StaticResource MonoFont}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="3"
                                    x:Name="ClearButton"
                                    Style="{StaticResource DangerButton}"
                                    Content="✕"
                                    Width="24" Height="24"
                                    Padding="0"
                                    FontSize="12"
                                    Margin="8,0,0,0"
                                    ToolTip="清空输入"
                                    Click="OnClearInput" />
                        </Grid>
                    </Border>

                    <!-- Input text area -->
                    <TextBox x:Name="InputBox"
                             Grid.Row="1"
                             Style="{StaticResource ModernTextBox}"
                             BorderThickness="0"
                             Background="Transparent"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="16,12"
                             FontSize="14"
                             TextChanged="OnInputTextChanged"
                             PreviewKeyDown="OnInputPreviewKeyDown"
                             PreviewKeyUp="OnInputPreviewKeyUp" />
                </Grid>
            </Border>

            <!-- ─── RIGHT: Result Card ──────────────────────────────── -->
            <Border x:Name="ResultCard"
                    Grid.Column="2"
                    Style="{StaticResource CardStyle}"
                    Padding="0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform X="0" Y="0" />
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </TransformGroup>
                </Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{StaticResource AccentGradientBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" x:Name="ResultLabel" Text="检查结果"
                                       Style="{StaticResource SectionLabel}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="2"
                                    x:Name="ExportButton"
                                    Style="{StaticResource ModernButton}"
                                    Content="📥 导出"
                                    Padding="10,3"
                                    FontSize="11"
                                    Margin="0,0,6,0"
                                    Click="OnExportResult" />
                            <Button Grid.Column="3"
                                    x:Name="CopyButton"
                                    Style="{StaticResource ModernButton}"
                                    Content="📋 复制"
                                    Padding="10,3"
                                    FontSize="11"
                                    Click="OnCopyResult" />
                        </Grid>
                    </Border>

                    <!-- Result display -->
                    <RichTextBox x:Name="ResultBox"
                                 Grid.Row="1"
                                 Style="{StaticResource ModernRichTextBox}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="16,12"
                                 FontSize="14"
                                 IsReadOnly="True" />
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             Suggestions Panel
             ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="SuggestionsPanel"
                Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20,10"
                Margin="0,0,0,6"
                Visibility="Collapsed"
                RenderTransformOrigin="0.5,0"
                Opacity="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" Opacity="0.3" ShadowDepth="4" Direction="270" Color="#000000" />
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform Y="30" />
            </Border.RenderTransform>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="SuggestionLabel" Text="💡 建议"
                           Style="{StaticResource SectionLabel}"
                           VerticalAlignment="Top"
                           Margin="0,2,16,0" />
                <ItemsControl x:Name="SuggestionsList"
                              Grid.Column="1">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1A2E"
                                    CornerRadius="6"
                                    Padding="10,6"
                                    Margin="0,0,8,6"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    Cursor="Hand">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{StaticResource ErrorBrush}"
                                               FontSize="12"
                                               Text="{Binding Original}" />
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"
                                               FontFamily="{StaticResource MonoFont}"
                                               Text="{Binding SuggestionText}"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Stats Bar
             ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="StatsBar" Grid.Row="3"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20,4"
                Height="40">
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" Opacity="0.3" ShadowDepth="4" Direction="270" Color="#000000" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>

                <!-- Available -->
                <Border Grid.Column="0" CornerRadius="6" Background="#0A2E1A" Padding="10,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="AvailableLabel"
                                   Text="可用：0"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontSize="11" FontFamily="{StaticResource MonoFont}"
                                   Margin="6,0,0,0" />
                    </Grid>
                </Border>

                <!-- Unavailable -->
                <Border Grid.Column="1" CornerRadius="6" Background="#2D1B1B" Padding="10,6" Margin="8,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="6" Height="6" Fill="{StaticResource ErrorBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="UnavailableLabel"
                                   Text="不可用：0"
                                   Foreground="{StaticResource ErrorBrush}"
                                   FontSize="11" FontFamily="{StaticResource MonoFont}"
                                   Margin="6,0,0,0" />
                    </Grid>
                </Border>

                <!-- Ignored -->
                <Border Grid.Column="2" CornerRadius="6" Background="#1A1A24" Padding="10,6" Margin="8,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="6" Height="6" Fill="{StaticResource IgnoredBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" x:Name="IgnoredLabel"
                                   Text="已忽略：0"
                                   Foreground="{StaticResource IgnoredBrush}"
                                   FontSize="11" FontFamily="{StaticResource MonoFont}"
                                   Margin="6,0,0,0" />
                    </Grid>
                </Border>

                <!-- Coverage progress bar -->
                <Grid Grid.Column="4" VerticalAlignment="Center">
                    <Border CornerRadius="6" Background="#1A1A24" Width="120" Height="8">
                        <Border x:Name="CoverageBar"
                                CornerRadius="6"
                                Background="{StaticResource AccentGradientBrush}"
                                HorizontalAlignment="Left"
                                Width="0" />
                    </Border>
                </Grid>

                <!-- Coverage text -->
                <TextBlock Grid.Column="6" x:Name="CoverageLabel"
                           Text="0%"
                           Foreground="{StaticResource AccentLightBrush}"
                           FontSize="13" FontWeight="SemiBold"
                           FontFamily="{StaticResource MonoFont}"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />
            </Grid>
        </Border>
    </Grid>
</Window>
